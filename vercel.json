{
  "functions": {
    "api/create-checkout.js": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/webhook.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js",
      "headers": {
        "x-vercel-body-parser-bypass": "true"
      }
    },
    {
      "src": "/api/create-checkout",
      "dest": "/api/create-checkout.js"
    }
  ]
}
